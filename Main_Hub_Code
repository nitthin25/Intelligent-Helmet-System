}

// 
// This function will no longer halt the code.
//
void initMPU6050() {
  Serial.print("Initializing MPU6050... ");

  if (!mpu.begin(0x68, &Wire)) {  // Try default I2C address
    Serial.println("❌ FAILED");
    Serial.println("⚠️  MPU6050 NOT FOUND! Accident detection will be DISABLED.");
    Serial.println("    - This is a HARDWARE problem. Check 3.3V power & pull-ups.");
    mpu_is_ready = false; // Set flag to false
  } else {
    // Configure MPU6050 settings
    mpu.setAccelerometerRange(MPU6050_RANGE_8_G);
    mpu.setGyroRange(MPU6050_RANGE_500_DEG);
    mpu.setFilterBandwidth(MPU6050_BAND_21_HZ);
    Serial.println("✓ OK");
    mpu_is_ready = true; // Set flag to true
  }
}

// 
// This function now checks for network registration
//
void initGSM() {
  Serial.print("Initializing SIM800L GSM... ");
  gsmSerial.begin(9600, SERIAL_8N1, GSM_RX_PIN, GSM_TX_PIN);
  delay(3000);  // Wait for GSM module boot

  // Send AT command test
  Serial.println("\nSending AT command...");
  gsmSerial.println("AT");
  delay(1000);

  if (gsmSerial.available()) {
    String response = gsmSerial.readString();
    if (response.indexOf("OK") >= 0) {
      Serial.println("✓ Module responded OK");
    } else {
      Serial.println("⚠️  Module responded but not OK");
    }
  } else {
    Serial.println("⚠️  No response! Check power/wiring.");
  }

  // Configure SMS text mode
  Serial.println("Setting SMS mode (AT+CMGF=1)...");
  gsmSerial.println("AT+CMGF=1");
  delay(1000);
  clearGSMBuffer();

  // Check network registration
  Serial.println("Checking network registration (AT+CREG?)...");
  unsigned long start_time = millis();
  bool registered = false;
  while (millis() - start_time < 30000) { // Wait up to 30s
    gsmSerial.println("AT+CREG?");
    delay(1000);
    if (gsmSerial.available()) {
      String response = gsmSerial.readString();
      // Check for "+CREG: 0,1" (Registered, home) or "+CREG: 0,5" (Registered, roaming)
      if (response.indexOf("+CREG: 0,1") >= 0 || response.indexOf("+CREG: 0,5") >= 0) {
        Serial.println("✓ Network registered!");
        registered = true;
        break;
      } else {
        Serial.println("    ...not registered, trying again...");
      }
    }
    delay(2000);
  }
  if (!registered) {
    Serial.println("❌ FAILED to register on network. SMS will likely fail.");
  }
  clearGSMBuffer();
}

void initDHT() {
  Serial.print("Initializing DHT11... ");
  dht.begin();
  // Add a quick check to see if DHT is found
  float temp = dht.readTemperature();
  if (isnan(temp)) {
    Serial.println("❌ FAILED! Check wiring to GPIO 4.");
  } else {
    Serial.println("✓ OK");
  }
}

// ═══════════════════════════════════════════════════════════════
//                 MQ SENSOR CALIBRATION
// ═══════════════════════════════════════════════════════════════

void startMQCalibration() {
  mq_warmup_start = millis();
  Serial.println("🔥 MQ Sensor Calibration Started");
  Serial.println("───────────────────────────────────────");
  Serial.println("    Phase 1: Warm-up (heating elements)");
  Serial.printf("    Duration: %d seconds\n", MQ_WARMUP_TIME / 1000);
  Serial.println("    MQ-135 (Air Quality) | MQ-3 (Alcohol)");
  Serial.println("    Please wait...\n");
}

// 
// ** MODIFIED v2.10 ** - Now uses separate multipliers
//
void handleMQCalibration() {
  unsigned long elapsed = millis() - mq_warmup_start;

  // Phase 1: Warm-up period
  if (elapsed < MQ_WARMUP_TIME) {
    // Progress update every 10 seconds
    static unsigned long last_update = 0;
    if (millis() - last_update > 10000) {
      last_update = millis();
      int seconds_left = (MQ_WARMUP_TIME - elapsed) / 1000;
      Serial.printf("⏳ Warm-up: %d seconds remaining...\n", seconds_left);
    }
    return;
  }

  // Phase 2: Baseline sampling
  Serial.println("\n✓ Warm-up complete!");
  Serial.println("───────────────────────────────────────");
  Serial.println("    Phase 2: Baseline Calibration");
  Serial.println("    ⚠️  Ensure sensors are in CLEAN AIR");
  Serial.println("    (No smoke, alcohol, or strong odors)\n");

  long mq135_sum = 0;
  long mq3_sum = 0;

  // Take multiple samples for accurate baseline
  for (int i = 0; i < MQ_SAMPLES_FOR_BASELINE; i++) {
    int mq135_reading = analogRead(MQ135_PIN);
    int mq3_reading = analogRead(MQ3_PIN);

    mq135_sum += mq135_reading;
    mq3_sum += mq3_reading;

    Serial.printf("    Sample %2d/%d: MQ-135=%4d | MQ-3=%4d\n", 
                  i+1, MQ_SAMPLES_FOR_BASELINE, mq135_reading, mq3_reading);

    delay(MQ_SAMPLE_INTERVAL);
  }

  // Calculate baseline (average of clean air)
  mq135_baseline = mq135_sum / MQ_SAMPLES_FOR_BASELINE;
  mq3_baseline = mq3_sum / MQ_SAMPLES_FOR_BASELINE;

  // ** MODIFIED v2.10 ** - Set dynamic thresholds using separate multipliers
  mq135_threshold = mq135_baseline * MQ135_THRESHOLD_MULTIPLIER;
  mq3_threshold = mq3_baseline * MQ3_THRESHOLD_MULTIPLIER;

  // Display results
  Serial.println("\n╔════════════════════════════════════════╗");
  Serial.println("║   CALIBRATION COMPLETE ✓               ║");
  Serial.println("╚════════════════════════════════════════╝");
  Serial.printf("📊 MQ-135 (Air): Baseline=%d | Threshold=%d (at %.2fx)\n", 
                mq135_baseline, mq135_threshold, MQ135_THRESHOLD_MULTIPLIER);
  Serial.printf("📊 MQ-3 (Alcohol): Baseline=%d | Threshold=%d (at %.2fx)\n", 
                mq3_baseline, mq3_threshold, MQ3_THRESHOLD_MULTIPLIER);
  Serial.println("───────────────────────────────────────");
  Serial.println("✓ Sensors ready for monitoring\n");

  mq_sensors_ready = true;

  // Success confirmation (2 beeps)
  shortBuzz();
  delay(150);
  shortBuzz();
}

