// ═══════════════════════════════════════════════════════════════
//                           SETUP (Re-ordered for power stability)
// ═══════════════════════════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  delay(2000);

  printHeader();

  // Configure non-sensor GPIO pins first
  pinMode(PANIC_BTN_PIN, INPUT_PULLUP);  // Internal pull-up resistor
  pinMode(MAIN_BUZZER_PIN, OUTPUT);
  digitalWrite(MAIN_BUZZER_PIN, LOW); // Buzzer starts OFF

  // Test buzzer functionality
  Serial.println("🔊 Testing buzzer...");
  testBuzzer();

  // -----------------------------------------------------------------
  // Initialize the high-power devices (GSM) FIRST.
  // -----------------------------------------------------------------
  
  Serial.println("\nInitializing high-power modules...");
  initGSM(); // This function now checks for network
  initDHT();
  Serial.println("✓ High-power modules initialized. Waiting for stability...");
  
  delay(2000); 

  // -----------------------------------------------------------------
  // Now initialize the sensitive MPU6050.
  // -----------------------------------------------------------------
  
  Serial.println("\nInitializing I2C bus and MPU6050...");
  Wire.begin(MPU_SDA_PIN, MPU_SCL_PIN);
  delay(100); // Give I2C bus time to settle
  
  // Initialize MPU6050 (This function is non-halting)
  initMPU6050(); 

  // Continue no matter what
  Serial.println("\n✓ System setup complete. Continuing to main loop...");
  Serial.println("📌 Panic Button: Press and hold for 1 second");
  Serial.println("⚡ Main Hub ready - Starting MQ sensor calibration...\n");

  // Begin MQ sensor warm-up process
  startMQCalibration();

  // Startup confirmation (2 beeps)
  shortBuzz();
  delay(200);
  shortBuzz();
}

// ═══════════════════════════════════════════════════════════════
//                         MAIN LOOP
// ═══════════════════════════════════════════════════════════════
void loop() {
  // Monitor panic button with debounce logic
  checkPanicButton();

  // Handle MQ sensor calibration if not complete
  if (!mq_sensors_ready) {
    handleMQCalibration();
  }

  // Monitor for crash/accident (only if MPU is ready)
  checkAccident();

  // Check environmental sensors (after calibration, with cooldown)
  // ** MODIFIED v2.20 ** - Removed environmental_alert_latch
  if (mq_sensors_ready && (millis() - last_env_alert_time > ALERT_COOLDOWN_MS)) {
    checkEnvironmentalAlerts();
  }

  // Handle the 5-second buzzer timer
  handleBuzzer();
  
  // Handle non-blocking SMS sending
  handleSmsSending();

  delay(100);  // 10Hz update rate
}

