void checkPanicButton() {
  int button_state = digitalRead(PANIC_BTN_PIN);
  bool button_is_pressed = (button_state == LOW);  // LOW = pressed (pull-up)

  // Debug: Show state changes
  static int last_state = HIGH;
  if (button_state != last_state) {
    Serial.printf("🔘 Button: %s\n", button_is_pressed ? "PRESSED ▼" : "RELEASED ▲");
    last_state = button_state;
  }

  // Button just pressed
  if (button_is_pressed && !button_was_pressed) {
    delay(BUTTON_DEBOUNCE_MS);  // Debounce
    
    if (digitalRead(PANIC_BTN_PIN) == LOW) {  // Verify still pressed
      button_was_pressed = true;
      button_press_start = millis();
      long_press_triggered = false;
      
      Serial.println("    Hold for 1 second to activate panic...");
      
      // Confirmation beep
      digitalWrite(MAIN_BUZZER_PIN, HIGH);
      delay(100);
      digitalWrite(MAIN_BUZZER_PIN, LOW);
    }
  }

  // Button being held
  if (button_is_pressed && button_was_pressed && !long_press_triggered) {
    unsigned long hold_time = millis() - button_press_start;
    
    if (hold_time >= BUTTON_LONG_PRESS_MS) {
      long_press_triggered = true;
      panic_button_pressed_latch = true;
      
      Serial.println("\n╔════════════════════════════════════════╗");
      Serial.println("║   🚨 PANIC ACTIVATED!                  ║");
      Serial.println("║   Emergency Alert Triggered            ║");
      Serial.println("╚════════════════════════════════════════╝\n");
      
      sendSmsAlert("🚨 PANIC BUTTON! Rider needs immediate help!");
      triggerBuzzer(5000); // Trigger buzzer for 5 seconds
    }
  }

  // Button released
  if (!button_is_pressed && button_was_pressed) {
    if (!long_press_triggered) {
      Serial.println("    Released early - No panic sent\n");
    }
    button_was_pressed = false;
  }
}

// 
// ** MODIFIED v2.15 ** - Replaced latch with a cooldown timer
//
void checkAccident() {
  // If the MPU is not ready, skip this function entirely.
  if (!mpu_is_ready) {
    return; 
  }

  // ** NEW v2.15 ** Check if we are in the 10-second cooldown period
  unsigned long current_time = millis();
  if (current_time - last_crash_alert_time < ALERT_COOLDOWN_MS) {
    return; // In cooldown, don't check for a new crash
  }

  sensors_event_t accel, gyro, temp;
  
  // Safety check to stop error flood
  if (!mpu.getEvent(&accel, &gyro, &temp)) {
    Serial.println("\n❌ ERROR: Failed to read MPU6050 during loop.");
    Serial.println("   This is a hardware power/signal issue.");
    Serial.println("   Accident detection is now DISABLED.");
    mpu_is_ready = false; // Disable MPU checking permanently
    return;
  }
  
  // Calculate total acceleration magnitude
  float total_accel = sqrt(
    accel.acceleration.x * accel.acceleration.x +
    accel.acceleration.y * accel.acceleration.y +
    accel.acceleration.z * accel.acceleration.z
  );

  // ** MODIFIED v2.15 ** - Removed 'accident_detected_latch' from this 'if'
  if (total_accel > CRASH_THRESHOLD) {
    
    // ** NEW v2.15 ** - Set the cooldown timer
    last_crash_alert_time = current_time;
    
    Serial.println("\n╔════════════════════════════════════════╗");
    Serial.println("║   ⚠️  CRASH DETECTED!                  ║");
    Serial.println("╚════════════════════════════════════════╝");
    Serial.printf("    Impact Force: %.2f m/s²\n", total_accel);
    Serial.printf("    Threshold: %.2f m/s²\n\n", CRASH_THRESHOLD);
    
    sendSmsAlert("⚠️ CRASH DETECTED! High impact force. Rider may need help!");
    triggerBuzzer(5000); // Trigger buzzer for 5 seconds
  }
}

// 
// ** MODIFIED v2.20 ** - Checks all sensors independently and uses timer
//
void checkEnvironmentalAlerts() {
  // ** LATCH REMOVED v2.20 **
  // We now rely on the 10-second cooldown in the main loop()
  
  String alert_message = "";
  bool alert_found = false; // Flag to track if we found anything

  // --- Alcohol check ---
  int alcohol = analogRead(MQ3_PIN);
  if (alcohol > mq3_threshold) {
    int percent_increase = ((alcohol - mq3_baseline) * 100) / mq3_baseline;
    alert_message += "🍺 ALCOHOL DETECTED! (+" + String(percent_increase) + "%)\n";
    alert_found = true;
  }

  // --- Air quality check ---
  int aqi = analogRead(MQ135_PIN);
  if (aqi > mq135_threshold) {
    int percent_increase = ((aqi - mq135_baseline) * 100) / mq135_baseline; 
    alert_message += "💨 POOR AIR QUALITY! (+" + String(percent_increase) + "%)\n";
    alert_found = true;
  }
  
  // --- Temperature check ---
  float temp = dht.readTemperature();
  if (!isnan(temp) && temp > TEMP_THRESHOLD) {
    alert_message += "🌡️ HIGH TEMPERATURE! " + String(temp, 1) + "°C\n";
    alert_found = true;
  }

  // Trigger alert if needed
  if (alert_found) {
    Serial.println("\n🚨 ENVIRONMENTAL ALERT DETECTED:\n" + alert_message);
    
    sendSmsAlert(alert_message); // Send the combined message
    triggerBuzzer(5000); // Trigger buzzer for 5 seconds
    
    // ** MODIFIED v2.20 **
    // Reset the cooldown timer so this function doesn't run
    // again for 10 seconds, preventing buzzer loops.
    last_env_alert_time = millis(); 
    
    // ** LATCH REMOVED v2.20 **
    // environmental_alert_latch = true; 
  }
}

// ═══════════════════════════════════════════════════════════════
//                 BUZZER TIMER FUNCTIONS (NEW v2.9)
// ═══════════════════════════════════════════════════════════════

/**
 * @brief Triggers the buzzer to turn on for a set duration.
 * @param duration_ms How long the buzzer should stay on (in milliseconds).
 */
void triggerBuzzer(unsigned long duration_ms) {
  buzzer_duration = duration_ms;
  buzzer_on_time = millis(); // Start the timer
}

/**
 * @brief Manages the buzzer timer. MUST be called in the main loop().
 */
void handleBuzzer() {
  if (buzzer_on_time > 0) {
    // Check if the buzzer duration has passed
    if (millis() - buzzer_on_time < buzzer_duration) {
      digitalWrite(MAIN_BUZZER_PIN, HIGH); // Buzzer ON
    } else {
      digitalWrite(MAIN_BUZZER_PIN, LOW);  // Buzzer OFF
      buzzer_on_time = 0; // Reset the timer
    }
  }
}


