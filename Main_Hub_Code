 */
String getGpsLocationString() {
  // GPS functionality has been removed.
  return "📍 Location: GPS module not installed";
}

/**
 * Queues an SMS alert to be sent by the state machine.
 */
void sendSmsAlert(String message) {
  if (alert_pending) {
    Serial.println("📤 SMS already in progress. New alert ignored.");
    return;
  }

  Serial.println("📤 Queuing emergency SMS...");
  Serial.println("───────────────────────────────────────");
  
  // ** THIS LINE IS NOW FIXED (v2.13) **
  alert_message_to_send = message + "\n" + getGpsLocationString() + 
                          "\n\n- Smart Helmet Alert System";
                          
  contact_index_to_send = 0; 
  alert_pending = true;
  sms_state = SMS_SEND_CMD; 
}

/**
 * NON-BLOCKING State Machine for sending SMS.
 */
void handleSmsSending() {
  if (!alert_pending) return;

  unsigned long current_millis = millis();

  switch (sms_state) {
    
    case SMS_IDLE:
      // Waiting state
      break;

    case SMS_SEND_CMD:
      if (contact_index_to_send < NUM_CONTACTS) {
        Serial.printf("  → Preparing for Contact %d: %s\n", 
                      contact_index_to_send + 1, EMERGENCY_CONTACTS[contact_index_to_send]);
        
        clearGSMBuffer(); 
        gsmSerial.println("AT+CMGS=\"" + String(EMERGENCY_CONTACTS[contact_index_to_send]) + "\"");
        
        sms_timer = current_millis;
        sms_state = SMS_SEND_BODY;
      } else {
        // We have sent to all contacts
        Serial.println("✓ All SMS alerts sent successfully\n");
        alert_pending = false;
        contact_index_to_send = 0;
        sms_state = SMS_IDLE;
      }
      break;

    case SMS_SEND_BODY:
      // Wait for the ">" prompt from the SIM800L
      if (gsmSerial.available()) {
        if (gsmSerial.readString().indexOf('>') >= 0) {
          Serial.println("    > prompt received. Sending body...");
          gsmSerial.print(alert_message_to_send);
          gsmSerial.write(26); // Ctrl+Z to send
          
          sms_timer = current_millis;
          sms_state = SMS_WAIT_RESPONSE;
        }
      }
      // ** MODIFIED v2.9 ** - Increased timeout to 5 seconds
      if (current_millis - sms_timer > 5000) { 
        Serial.println("    ❌ No '>' prompt. Aborting contact.");
        contact_index_to_send++; // Move to next contact
        sms_state = SMS_SEND_CMD;
      }
      break;

    case SMS_WAIT_RESPONSE:
      // Wait up to 10 seconds for the "OK" or "ERROR" response
      if (gsmSerial.available()) {
        String response = gsmSerial.readString();
        if (response.indexOf("OK") >= 0) {
           Serial.println("    ✓ SMS sent successfully.");
        } else if (response.indexOf("ERROR") >= 0) {
           Serial.println("    ❌ SMS send ERROR.");
        }
      }
      
      if (current_millis - sms_timer > 10000) { 
        Serial.println("    → Send complete (or timed out). Moving to next contact.");
        clearGSMBuffer();
        contact_index_to_send++; // Move to next contact
        sms_state = SMS_SEND_CMD;
      }
      break;
  }
}

