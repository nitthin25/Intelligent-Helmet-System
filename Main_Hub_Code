void shortBuzz() {
  digitalWrite(MAIN_BUZZER_PIN, HIGH);
  delay(SHORT_BUZZ_DURATION);
  digitalWrite(MAIN_BUZZER_PIN, LOW);
}

void clearGSMBuffer() {
  while (gsmSerial.available()) {
    gsmSerial.read();
  }
}
