void testBuzzer() {
  Serial.println("    Testing 3-beep pattern...");
  for (int i = 0; i < 3; i++) {
    digitalWrite(MAIN_BUZZER_PIN, HIGH);
    Serial.printf("    Beep %d - ON\n", i+1);
    delay(150);
    digitalWrite(MAIN_BUZZER_PIN, LOW);
    Serial.println("          OFF");
